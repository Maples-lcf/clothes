# 复制为 admin/.env.local 或 mobile/.env.local 并填入 Supabase 项目信息
# Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 本地开发 AI 出图（npm run dev 时使用，写入 admin/.env.local）
REMOVEBG_API_KEY=your-remove-bg-api-key

# AI 闲鱼文案（视觉模型，写入 mobile/.env.local 或 Supabase Edge Function Secrets）
# 通义千问（推荐国内）：https://dashscope.console.aliyun.com/
AI_VISION_API_KEY=your-dashscope-or-openai-api-key
AI_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_VISION_MODEL=qwen-vl-max
# OpenAI 示例：
# AI_VISION_BASE_URL=https://api.openai.com/v1
# AI_VISION_MODEL=gpt-4o-mini

# 超管：登录页邮箱填 admin，密码填下面这个
VITE_SUPER_ADMIN_EMAIL=admin@clothes.local
VITE_SUPER_ADMIN_PASSWORD=your-super-admin-password

# AI 出图（Supabase Edge Function generate-product-image）
# 在 Supabase Dashboard → Edge Functions → Secrets 中配置 REMOVEBG_API_KEY
# 申请地址：https://www.remove.bg/api
